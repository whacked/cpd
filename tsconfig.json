{
    "compilerOptions": {
        "module": "CommonJS",
        "target": "ES2015",
        "declaration": true,
        "outDir": "./dist",
        "allowSyntheticDefaultImports": true,
        "moduleResolution": "node",
        "esModuleInterop": true,
        "resolveJsonModule": true
    },
    "include": [
        "src/**/*",
        "src/**/*.json"
    ]
}